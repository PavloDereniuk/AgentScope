{
  "name": "@agentscope/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./schemas": {
      "types": "./src/schemas.ts",
      "import": "./dist/src/schemas.js",
      "default": "./dist/src/schemas.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./dist/src/types.js",
      "default": "./dist/src/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
