{
  "name": "@agentscopehq/agent-kit-sdk",
  "version": "0.1.0-alpha.1",
  "description": "AgentScope observability wrapper for Solana Agent Kit — hooks every tool call into OpenTelemetry spans the AgentScope API can ingest.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://agentscope.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PavloDereniuk/AgentScope.git",
    "directory": "packages/agent-kit-sdk"
  },
  "bugs": {
    "url": "https://github.com/PavloDereniuk/AgentScope/issues"
  },
  "keywords": ["solana", "agent", "observability", "opentelemetry", "solana-agent-kit"],
  "peerDependencies": {
    "solana-agent-kit": "*"
  },
  "peerDependenciesMeta": {
    "solana-agent-kit": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist .turbo"
  }
}
