# ============================================================
# AgentScope — Environment variables (template)
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Node env ---
NODE_ENV=development

# --- Database (Supabase Postgres) ---
# Get from: Supabase project → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# --- Solana RPC (Helius free tier) ---
# Sign up at: https://helius.dev → Dashboard → API Key
HELIUS_API_KEY=
SOLANA_NETWORK=mainnet
# Helius mainnet HTTP RPC: https://mainnet.helius-rpc.com/?api-key=<KEY>
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
# Helius mainnet WebSocket (optional override):
# SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=
# Yellowstone gRPC endpoint (provided by Helius, post-MVP)
YELLOWSTONE_GRPC_URL=
YELLOWSTONE_GRPC_TOKEN=

# --- Auth (Privy) ---
# Get from: https://dashboard.privy.io → Apps → Settings
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Frontend (exposed in dashboard build)
VITE_PRIVY_APP_ID=

# --- Alerting (Telegram) ---
# Create bot via @BotFather on Telegram, copy token here
TELEGRAM_BOT_TOKEN=
# Default chat for testing (your personal chat ID)
TELEGRAM_DEFAULT_CHAT_ID=

# --- API base URLs (frontend) ---
VITE_API_BASE_URL=http://localhost:3000

# --- Anomaly detector thresholds ---
AGENTSCOPE_SLIPPAGE_PCT_THRESHOLD=5
AGENTSCOPE_GAS_MULT_THRESHOLD=3
AGENTSCOPE_DRAWDOWN_PCT_THRESHOLD=10
AGENTSCOPE_ERROR_RATE_PCT_THRESHOLD=20
AGENTSCOPE_STALE_MINUTES_THRESHOLD=30

# --- Logging ---
LOG_LEVEL=debug
