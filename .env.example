# ============================================================
# AgentScope — Environment variables (template)
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Node env ---
NODE_ENV=development

# --- Database (Supabase Postgres) ---
# Get from: Supabase project → Settings → Database → Connection String
# → "Transaction" mode (port 6543, pooled) — required for IPv4 + Railway/Vercel.
# The "Direct" connection (5432) needs an IPv4 add-on on the Free plan.
DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Solana RPC (Helius free tier) ---
# Sign up at: https://helius.dev → Dashboard → API Key
HELIUS_API_KEY=
SOLANA_NETWORK=mainnet
# Helius mainnet HTTP RPC: https://mainnet.helius-rpc.com/?api-key=<KEY>
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
# Helius mainnet WebSocket (optional override):
# SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=
# Yellowstone gRPC endpoint (provided by Helius, post-MVP)
YELLOWSTONE_GRPC_URL=
YELLOWSTONE_GRPC_TOKEN=

# --- Auth (Privy) ---
# Get from: https://dashboard.privy.io → Apps → Settings
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Frontend (exposed in dashboard build)
VITE_PRIVY_APP_ID=

# --- Alerting (Telegram) ---
# Create bot via @BotFather on Telegram, copy token here
TELEGRAM_BOT_TOKEN=
# Bot username (without @). Used by `/api/telegram/init` to generate the
# `t.me/<bot>?start=<code>` deep-link. If unset, the linking dialog returns
# 503 and users have to enter chat_id manually in Settings.
TELEGRAM_BOT_USERNAME=
# Optional admin chat for the abuse-monitor (Epic 14 Phase 3) — receives
# "N new users in last M min" warnings when the signup-spike monitor trips.
# Leave unset for log-only mode (the monitor still runs, just silent).
TELEGRAM_ADMIN_CHAT_ID=
# DEPRECATED — do NOT set in production. Per-agent chat_id now travels on
# each AlertMessage (E14 Phase 1). Setting this in prod would silently
# re-route every new tenant's alerts to the platform owner's chat.
# Local dev only: kept for one-shot scripts (seed-anomaly-alert,
# trigger-anomaly) when an agent has no telegram_chat_id column yet.
TELEGRAM_DEFAULT_CHAT_ID=

# --- API base URLs (frontend) ---
# Leave unset in local dev so the Vite dev-proxy keeps requests
# same-origin (no CORS needed). Set to the Railway API URL in
# production (Vercel env) so the dashboard calls the API directly.
# Example prod value: https://api.agentscopehq.dev
VITE_API_BASE_URL=

# --- API CORS (backend) ---
# Comma-separated list of browser origins allowed to call the API
# cross-origin. Required in production because the dashboard (Vercel)
# and API (Railway) live on different hosts. Leave empty in local dev
# — same-origin via the Vite proxy needs no CORS headers.
# Example: https://app.agentscopehq.dev,https://agentscopehq.dev
DASHBOARD_ORIGINS=

# Landing page URL — dashboard redirects here on sign-out.
# Local dev: http://localhost:4321 (Astro default)
# Production: https://<your-landing-domain>
VITE_LANDING_URL=http://localhost:4321

# --- Multi-tenant abuse hardening (Epic 14 Phase 3) ---
# Hard cap on agents one Privy user can own. Default in code is 2 —
# tight for public beta to protect Helius free-tier + Supabase row budget.
MAX_AGENTS_PER_USER=2
# Comma-separated Privy DIDs that bypass the per-user agent cap entirely.
# Use for the platform owner / load-test accounts. Per-IP throttle (3/24h)
# and signup-spike monitor still apply — only the cap is skipped.
# Example: did:privy:cmxxxxxx,did:privy:cmyyyyyy
OWNER_PRIVY_DIDS=

# --- Anomaly detector thresholds ---
AGENTSCOPE_SLIPPAGE_PCT_THRESHOLD=5
AGENTSCOPE_GAS_MULT_THRESHOLD=3
AGENTSCOPE_DRAWDOWN_PCT_THRESHOLD=10
AGENTSCOPE_ERROR_RATE_PCT_THRESHOLD=20
AGENTSCOPE_STALE_MINUTES_THRESHOLD=30

# --- Internal service-to-service auth ---
# Shared secret between API (apps/api) and ingestion worker
# (apps/ingestion). Generate once and set the same value in both services:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Required in production. Used by ingestion → API on `POST /internal/publish`
# to push tx/alert events into the SSE bus without exposing it externally.
INTERNAL_SECRET=
# Public URL of the API service the ingestion worker calls back into.
# Production: https://api.agentscopehq.dev (or the Railway URL).
# Local dev: http://localhost:3000
API_INTERNAL_URL=http://localhost:3000

# --- Logging ---
LOG_LEVEL=debug
