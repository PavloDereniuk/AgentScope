{
  "name": "@agentscope/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "start": "node dist/server.js",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentscope/db": "workspace:^",
    "@agentscope/shared": "workspace:^",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@privy-io/server-auth": "^1.32.5",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2"
  }
}
