# Astro exposes only PUBLIC_* variables to the client bundle.
# Copy this file to .env and adjust for your environment.

# URL of the deployed dashboard SPA (used by Hero CTA and nav).
# Local dev: http://localhost:5173
# Production: https://app.agentscopehq.dev
PUBLIC_DASHBOARD_URL=http://localhost:5173

# Canonical site URL used for OG tags, Twitter cards, canonical links.
# Local dev: http://localhost:4321
# Production: https://<your-landing-domain>
PUBLIC_SITE_URL=http://localhost:4321
