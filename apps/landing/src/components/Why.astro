---
const stats = [
  {
    idx: '01',
    label: 'AGENT PAYMENTS',
    value: '15M',
    unit: '+',
    desc: 'AI-agent on-chain payments processed on Solana',
    source: 'Solana Foundation, March 2026',
  },
  {
    idx: '02',
    label: 'X402 SHARE',
    value: '49.7',
    unit: '%',
    desc: 'of all x402 transactions happen on Solana',
    source: 'SolanaFloor / Dune, Feb 2026',
  },
  {
    idx: '03',
    label: 'AGENT TX SHARE · 2 YR',
    value: '99.99',
    unit: '%',
    desc: 'of all on-chain transactions, in two years, will be driven by agents, bots, and LLM-based wallets',
    source: 'Vibhu Norby, Solana Foundation AI Lead, March 2026',
  },
  {
    idx: '04',
    label: 'REASONING HALLUCINATION',
    value: '>10',
    unit: '%',
    desc: 'of output from every frontier reasoning model (GPT-5, Claude 4.5, Grok-4) is hallucinated — and the rate scales with reasoning ability',
    source: 'Vectara HHEM benchmark, 2026',
  },
];
---

<section class="problem shell" id="why">
  <div class="section-label"><span class="dot"></span>02 — WHY</div>

  <div class="problem-head">
    <h2>
      Agents ship code.<br />
      <span class="dim">Agents ship capital.</span><br />
      No one watches them.
    </h2>
    <p>
      Existing AI observability stops at the LLM call. Solana explorers stop
      at the transaction. Neither knows <em>why</em> an agent made a trade —
      and by the time something breaks, funds are already gone.
    </p>
  </div>

  <div class="stats">
    {stats.map((stat) => (
      <div class="stat">
        <div class="stat-idx">{stat.idx}</div>
        <div class="stat-label">{stat.label}</div>
        <div class="stat-num">{stat.value}<span class="unit">{stat.unit}</span></div>
        <div class="stat-desc">
          {stat.desc}
          <span class="stat-source">— {stat.source}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .stat-source {
    display: block;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--fg-3);
    letter-spacing: 0.04em;
  }
  h2 em {
    font-style: italic;
    color: var(--fg);
  }
</style>
