---
interface Props {
  dashboardUrl?: string;
  repoUrl?: string;
}

const {
  dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL ?? 'https://app.agentscopehq.dev',
  repoUrl = 'https://github.com/PavloDereniuk/agentscope',
} = Astro.props;
---

<section class="cta shell">
  <div class="cta-inner">
    <div class="section-label cta-label">
      <span class="dot"></span>06 — SHIP IT
    </div>
    <h2>
      Stop watching explorers.<br />
      Start watching <em>agents.</em>
    </h2>
    <p>
      Open source. MIT. Runs on Railway + Vercel + Supabase. Deploy your own
      instance in minutes — or try the hosted demo.
    </p>
    <div class="cta-btns">
      <a href={dashboardUrl} class="btn btn-primary btn-lg">Start monitoring →</a>
