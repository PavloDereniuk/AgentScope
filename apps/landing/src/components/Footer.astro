  <div class="footer-bottom">
    <span>© {year} AGENTSCOPE · SOLANA · OPEN SOURCE</span>
    <span class="status-pill" role="status" aria-live="polite">
      <span class="status-dot"></span>
      STREAMING
      <span class="status-sep">·</span>
