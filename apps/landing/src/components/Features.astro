---
const features = [
  {
    icon: '📋',
    title: 'Agent Registry',
    desc: 'Register any Solana wallet as an AI agent. One place to manage identities, ingest tokens, and metadata.',
  },
  {
    icon: '⛓️',
    title: 'On-chain Ingestion',
    desc: 'Real-time WebSocket listener parses Jupiter v6 swaps and Kamino Lend operations into structured events.',
  },
  {
    icon: '🧠',
    title: 'Reasoning Traces',
    desc: 'OpenTelemetry spans capture every decision step — prompts, model calls, tool invocations — and correlate them to on-chain tx.',
  },
  {
    icon: '🚨',
    title: 'Anomaly Detection',
    desc: 'Rule-based detector flags high slippage, gas spikes, large drawdowns, error bursts, and stale agents automatically.',
  },
  {
    icon: '📊',
    title: 'Live Dashboard',
    desc: 'Transaction timeline, PnL chart, reasoning tree, and SSE-streamed alert feed — all in one SPA.',
  },
  {
    icon: '🔌',
    title: 'SDK Integrations',
    desc: 'Two-line setup for ElizaOS agents (wrapActions) and Solana Agent Kit agents (traced). Spans ship automatically.',
  },
];
---

<section class="bg-gray-900 py-20 px-6">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-3xl font-bold text-white">Everything your agent needs to be observable</h2>
    <p class="mt-3 text-center text-gray-400">Built for the Solana AI agent ecosystem, from day one.</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-xl border border-gray-800 bg-gray-950 p-6 hover:border-green-800 transition-colors">
          <div class="text-3xl mb-3">{f.icon}</div>
          <h3 class="text-lg font-semibold text-white">{f.title}</h3>
          <p class="mt-2 text-sm text-gray-400 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
