---
interface Props {
  repoUrl?: string;
}

const { repoUrl = 'https://github.com/PavloDereniuk/agentscope' } = Astro.props;

const links = [
  { href: '#features', label: 'Features', id: 'features' },
  { href: '#integrate', label: 'Integrate', id: 'integrate' },
  { href: '#preview', label: 'Preview', id: 'preview' },
];
---

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="AgentScope home">
      <span class="logo-mark">
        <svg viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <rect x="1" y="1" width="20" height="20" rx="4" stroke="currentColor" stroke-width="1.5" />
          <circle cx="11" cy="11" r="4" stroke="currentColor" stroke-width="1.5" />
          <circle cx="11" cy="11" r="1.5" fill="var(--accent)" />
        </svg>
      </span>
      agentscope<sup>v0.9</sup>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((link) => (
        <a href={link.href} data-nav-link={link.id}>{link.label}</a>
      ))}
    </nav>

    <div class="nav-cta">
      <a
        class="btn btn-ghost nav-star"
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Star AgentScope on GitHub"
      >
        <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
        </svg>
        <span>Star</span>
      </a>
      <button
        type="button"
        class="btn btn-ghost nav-tweaks-toggle"
        aria-label="Open tweaks panel"
        aria-pressed="false"
        data-tweaks-toggle
      >
        <svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="8" cy="8" r="2.5" />
          <path d="M8 0.5v3M8 12.5v3M15.5 8h-3M3.5 8h-3M13.3 2.7l-2.1 2.1M4.8 11.2l-2.1 2.1M13.3 13.3l-2.1-2.1M4.8 4.8L2.7 2.7" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Active link highlight — driven by aria-current from scroll-spy */
  .nav-links a {
    transition: color 0.15s ease;
  }
  .nav-links a[aria-current="true"] {
    color: var(--fg);
  }

  /* Focus-visible outlines for keyboard nav */
  .nav :is(a, button):focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* Square tweaks button */
  .nav-tweaks-toggle {
    width: 36px;
    padding: 0;
    justify-content: center;
  }
  .nav-tweaks-toggle svg {
    transition: transform 0.25s ease;
  }
  .nav-tweaks-toggle:hover svg,
  .nav-tweaks-toggle[aria-pressed="true"] svg {
    transform: rotate(45deg);
  }
  .nav-tweaks-toggle[aria-pressed="true"] {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>

<script>
  // Scroll-spy: sets aria-current on link whose section is closest to viewport top.
  const links = document.querySelectorAll<HTMLAnchorElement>(".nav-links [data-nav-link]");
  const targets: HTMLElement[] = [];
  for (const link of links) {
    const id = link.dataset.navLink;
    const el = id ? document.getElementById(id) : null;
    if (el) targets.push(el);
  }

  if (targets.length > 0 && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            for (const link of links) {
              if (link.dataset.navLink === id) {
                link.setAttribute("aria-current", "true");
              } else {
                link.removeAttribute("aria-current");
              }
            }
          }
        }
      },
      { rootMargin: "-40% 0px -55% 0px", threshold: 0 },
    );
    for (const t of targets) observer.observe(t);
  }

  // Tweaks toggle: flips data-tweaks on <html>; full panel wired in E11.13.
  const toggle = document.querySelector<HTMLButtonElement>("[data-tweaks-toggle]");
  toggle?.addEventListener("click", () => {
    const html = document.documentElement;
    const next = html.dataset.tweaks === "on" ? "off" : "on";
    html.dataset.tweaks = next;
    toggle.setAttribute("aria-pressed", next === "on" ? "true" : "false");
  });
</script>
