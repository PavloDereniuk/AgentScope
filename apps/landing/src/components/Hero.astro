---
const DASHBOARD_URL = import.meta.env.PUBLIC_DASHBOARD_URL ?? 'https://app.agentscopehq.dev';
---

<section class="hero-section">
  <div class="hero shell">
    <div class="hero-inner">
      <div>
        <div class="hero-eyebrow">
          <span class="pulse"></span>
          15M+ AGENT TX ON SOLANA · ZERO TELEMETRY
        </div>

        <h1 class="hero-title">
          Your AI agents are<br />
          trading <em>blind.</em><br />
          <span class="mono">// observe everything.</span>
        </h1>

        <p class="hero-sub">
          Full-stack observability for on-chain AI agents. Registry, transaction
          tracing, OpenTelemetry reasoning logs, rule-based anomaly detection
          and Telegram alerts — in one place.
        </p>

        <div class="hero-cta-row">
          <a href={DASHBOARD_URL} class="btn btn-primary btn-lg">Start monitoring →</a>
          <a href="#preview" class="btn btn-ghost btn-lg">See the dashboard</a>
        </div>

        <div class="hero-meta">
          <div><strong>&lt; 1s</strong>SSE latency</div>
          <div><strong>8</strong>anomaly rules</div>
          <div><strong>2</strong>SDKs: eliza · agent-kit</div>
          <div><strong>OSS</strong>MIT · built in public</div>
        </div>
      </div>

      <div class="term-wrap">
        <div class="term" id="hero-terminal" aria-label="Live agent event stream">
          <div class="term-head">
            <div class="term-dots"><span></span><span></span><span></span></div>
            <span class="term-live">live · /v1/agents/:id/stream</span>
            <span>00:04:12</span>
          </div>
          <div class="term-body">
            <div><span class="prompt">$</span> <span>agentscope watch <span class="str">7fK2…Qz8n</span></span></div>
            <div class="dim">  → subscribed to https://api.agentscopehq.dev</div>
            <div class="dim">  → press Ctrl+C to exit</div>
            <div>&nbsp;</div>
            <div><span class="dim">12:34:51</span> <span class="ok">●</span> <span class="kw">tx.new      </span> <span class="str">5vKx3J…ze8Jp9</span></div>
            <div><span class="dim">12:34:52</span> <span class="ok">●</span> <span class="kw">tx.new      </span> <span class="str">2pqMnV…wXfLxQ</span></div>
            <div><span class="dim">12:34:54</span> <span class="err">▲</span> <span class="err">alert.warning</span>  <span class="str">slip_a1b</span></div>
            <div><span class="dim">12:34:58</span> <span class="ok">●</span> <span class="kw">tx.new      </span> <span class="str">9YHrD3…sM8GpR</span></div>
            <div><span class="dim">12:35:01</span> <span class="err">▲</span> <span class="err">alert.critical</span> <span class="str">slip_b2c</span></div>
            <div>&nbsp;</div>
            <div><span class="prompt">$</span> <span id="term-cursor" aria-hidden="true">_</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Blinking cursor in hero terminal. Paused when user prefers reduced motion.
  const cursor = document.getElementById("term-cursor");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (cursor && !prefersReduced) {
    let on = true;
    setInterval(() => {
      on = !on;
      cursor.style.opacity = on ? "1" : "0.15";
    }, 520);
  }
</script>
