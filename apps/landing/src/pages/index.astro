---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Why from '../components/Why.astro';
import Features from '../components/Features.astro';
import Integrate from '../components/Integrate.astro';
import ProductPreview from '../components/ProductPreview.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="AgentScope — Observability for Solana AI Agents"
  description="Register your on-chain agent, instrument in 5 lines, get full observability."
>
  <Nav />

  <main>
    <Hero />
    <Marquee />
    <Why />
    <Features />
    <Integrate />
    <ProductPreview />
    <CTA />
  </main>

  <Footer />
</BaseLayout>
