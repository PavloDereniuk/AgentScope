{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "HELIUS_API_KEY",
    "PRIVY_APP_ID",
    "PRIVY_APP_SECRET",
    "TELEGRAM_BOT_TOKEN",
    "AGENTSCOPE_SLIPPAGE_PCT_THRESHOLD",
    "AGENTSCOPE_GAS_MULT_THRESHOLD",
    "AGENTSCOPE_DRAWDOWN_PCT_THRESHOLD",
    "AGENTSCOPE_ERROR_RATE_PCT_THRESHOLD",
    "AGENTSCOPE_STALE_MINUTES_THRESHOLD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
